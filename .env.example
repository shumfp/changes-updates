# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Registration Changes integrations ───────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GOOGLE_SERVICE_ACCOUNT_JSON=
SHEET_ID=
SHEET_TAB_NAME=Sheet1
SHEET_GID=0
SHEET_DEFAULT_UPDATE_COLUMN=C
# Optional JSON object, e.g. {"session_time":"C","dietary_requirement":"D"}
SHEET_FIELD_COLUMN_MAP=
RESEND_API_KEY=
ACK_FROM_EMAIL=Registration Changes <onboarding@resend.dev>

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
# For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Your price IDs from Stripe dashboard → Products
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_

# ── Stripe Connect (set by Vibe Launchpad when provisioned via platform) ────
# Leave blank if running standalone with your own Stripe account
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_PLATFORM_FEE_PERCENT=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
